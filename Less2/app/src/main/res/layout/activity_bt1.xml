<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="TÍNH ĐIỂM TRUNG BÌNH VÀ XẾP LOẠI"
        android:textColor="#3F51B5"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/edtTen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Tên học sinh" />

    <EditText
        android:id="@+id/edtToan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập điểm Toán"
        android:inputType="numberDecimal" />

    <EditText
        android:id="@+id/edtLy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập điểm Lý"
        android:inputType="numberDecimal" />

    <EditText
        android:id="@+id/edtHoa"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập điểm Hóa"
        android:inputType="numberDecimal" />

    <Button
        android:id="@+id/btnTinh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="TÍNH"
        android:layout_marginTop="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Điểm trung bình:"
        android:layout_marginTop="16dp" />

    <EditText
        android:id="@+id/edtDTB"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:focusable="false" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Xếp loại:" />

    <EditText
        android:id="@+id/edtXepLoai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:focusable="false" />

</LinearLayout>